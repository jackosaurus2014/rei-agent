# === REQUIRED ===
ANTHROPIC_API_KEY=          # Get at console.anthropic.com
TAVILY_API_KEY=             # Get at tavily.com (1,000 free searches/month)

# === PHASE 2 — Recommended for better rental data ===
RENTCAST_API_KEY=           # rentcast.io — $19/mo starter, 50 free calls/month

# === PHASE 3 — For authoritative property/ownership data at scale ===
ATTOM_API_KEY=              # attomdata.com — $199/mo, free trial available

# === FREE APIs (no key needed, but register for higher limits) ===
CENSUS_API_KEY=             # api.census.gov/data/key_signup.html (free)

# === AGENT SETTINGS ===
LOG_LEVEL=info              # debug | info | warn | error
OUTPUT_DIR=./output         # Where to save generated memos
MAX_SEARCH_RESULTS=5        # Tavily results per query (5 = good balance of cost/quality)
AGENT_MAX_ITERATIONS=15     # Max tool-use loops per agent

# === UNDERWRITING DEFAULTS ===
ASSUMED_RATE=7.5            # Assumed interest rate % for DSCR calculations
EXPENSE_RATIO=0.40          # Operating expense ratio (40% of gross rent is standard)
MIN_DSCR=1.25               # Minimum acceptable DSCR (hard gate)
